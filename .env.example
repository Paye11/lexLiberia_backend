# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/lexliberia

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Admin bootstrap (created on first startup if missing)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Frontend URL for CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000

# Email (optional — messages/notices still saved if SMTP is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="LexLiberia <noreply@example.com>"
